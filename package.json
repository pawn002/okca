{
  "name": "okca",
  "version": "1.0.0",
  "description": "OK Contrast Algorithm — OKLCH-native, WCAG-compatible contrast ratio with zero false passes",
  "author": "John Z. Rioflorido",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "test": "jest"
  },
  "devDependencies": {
    "colorjs.io": "^0.5.2",
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pawn002/okca.git"
  },
  "homepage": "https://github.com/pawn002/okca",
  "bugs": {
    "url": "https://github.com/pawn002/okca/issues"
  },
  "license": "MIT",
  "keywords": [
    "contrast",
    "accessibility",
    "a11y",
    "oklch",
    "wcag",
    "color",
    "perceptual",
    "okca"
  ],
  "jest": {
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "tsconfig": {
            "module": "commonjs",
            "target": "ES2021",
            "skipLibCheck": true,
            "esModuleInterop": true,
            "types": ["jest", "node"]
          }
        }
      ]
    },
    "testEnvironment": "node"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
